# Firebase config (live habit counts feature). Copy this file to
# `.env.local` and fill in the values from the Firebase console.
# When any required value (apiKey, projectId, appId) is missing, the
# live-counts feature is silently disabled — the rest of the app works
# unchanged. See FIREBASE_SETUP.md for setup steps.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
