rules_version = '2';

// Security rules for the live habit-count feature.
// - Public counts (`habitCounts/{date}`) are readable by any authenticated
//   user (including anonymous) and writable by them. The client uses a
//   Firestore transaction that reads + writes within a single op so the
//   increment is atomic. Tightening this further requires a Cloud Function
//   trigger and a separate write-only "events" collection.
// - Per-user tick records (`habitTicks/{uid}/days/{date}`) are isolated to
//   the owning user, so a user can only mark themselves as having ticked.

service cloud.firestore {
  match /databases/{database}/documents {

    match /habitCounts/{date} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /habitTicks/{uid}/days/{date} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Soft "live counts" for non-habit activities — autophagy fasts and
    // dopamine resets. Same shape as habitCounts: public daily totals any
    // authenticated user can read and atomic-increment via a transaction.
    // The per-user `*Ticks` doc prevents one user from inflating the
    // counter by tapping multiple times.

    match /autophagyCounts/{date} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /autophagyTicks/{uid}/days/{date} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /resetCounts/{date} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /resetTicks/{uid}/days/{date} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Per-user cloud-sync snapshot (full Zustand state). Owner-only.
    match /userSnapshots/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Workspaces (shared pair/group spaces) ────────────────────────
    // A workspace doc carries `memberUids[]` for cheap membership checks
    // inside rules. The owner controls everything; members can only add
    // themselves (join) or remove themselves (leave). Joins are capped
    // at `maxMembers` and only allowed when the diff is exactly "add
    // myself" — no piggybacking other field changes.

    match /workspaces/{wsId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberUids;

      // Owner creates. Must include themselves in memberUids and be the
      // declared ownerUid.
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerUid
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.memberUids.size() == 1;

      allow update: if request.auth != null && (
        // Owner can update anything on their workspace.
        request.auth.uid == resource.data.ownerUid
        // Or: a non-member is joining — diff must be ONLY memberUids and
        // ONLY the addition of themselves, capped at maxMembers.
        || (
          !(request.auth.uid in resource.data.memberUids)
          && request.auth.uid in request.resource.data.memberUids
          && request.resource.data.memberUids.size()
             == resource.data.memberUids.size() + 1
          && request.resource.data.memberUids.size()
             <= resource.data.maxMembers
          && request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['memberUids'])
        )
        // Or: an existing member is leaving — diff is ONLY memberUids
        // shrinking by their own uid.
        || (
          request.auth.uid in resource.data.memberUids
          && !(request.auth.uid in request.resource.data.memberUids)
          && request.resource.data.memberUids.size()
             == resource.data.memberUids.size() - 1
          && request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['memberUids'])
        )
      );

      allow delete: if request.auth != null
        && request.auth.uid == resource.data.ownerUid;

      // Each member doc holds denormalized display info (name, photoURL).
      // Reads are gated on being a member of the parent workspace; writes
      // are restricted to the doc's own uid (or the owner, for kicks).
      match /members/{memberUid} {
        allow read: if request.auth != null
          && request.auth.uid in get(
            /databases/$(database)/documents/workspaces/$(wsId)
          ).data.memberUids;
        allow create, update: if request.auth != null
          && request.auth.uid == memberUid;
        allow delete: if request.auth != null && (
          request.auth.uid == memberUid
          || request.auth.uid == get(
            /databases/$(database)/documents/workspaces/$(wsId)
          ).data.ownerUid
        );
      }

      // Shared habit definitions (phase 2a). Members read; only the
      // workspace owner can create / update / delete.
      match /habits/{habitId} {
        allow read: if request.auth != null
          && request.auth.uid in get(
            /databases/$(database)/documents/workspaces/$(wsId)
          ).data.memberUids;
        allow create, update, delete: if request.auth != null
          && request.auth.uid == get(
            /databases/$(database)/documents/workspaces/$(wsId)
          ).data.ownerUid;
      }

      // Per-member daily logs for the shared habits. Each member writes
      // only their own logs; every member can read any other member's
      // logs (that read is what makes the space "shared"). Read gate is
      // workspace membership; write gate is "you can only write your own".
      // Delete gate has an additional owner exception so the cascade
      // inside deleteWorkspace can clean every member's logs before
      // removing the parent.
      match /logs/{logUid}/days/{date} {
        allow read: if request.auth != null
          && request.auth.uid in get(
            /databases/$(database)/documents/workspaces/$(wsId)
          ).data.memberUids;

        // Create / update: still self-only.
        allow create, update: if request.auth != null
          && request.auth.uid == logUid
          && request.auth.uid in get(
            /databases/$(database)/documents/workspaces/$(wsId)
          ).data.memberUids;

        // Delete: the doc's own uid (used by the "wipe my history"
        // leave path), OR the workspace owner (cascade-on-workspace-
        // delete). Owner can already destroy the whole workspace, so
        // letting them delete individual member logs is a smaller
        // power than what they already have.
        allow delete: if request.auth != null && (
          (
            request.auth.uid == logUid
            && request.auth.uid in get(
              /databases/$(database)/documents/workspaces/$(wsId)
            ).data.memberUids
          )
          || request.auth.uid == get(
            /databases/$(database)/documents/workspaces/$(wsId)
          ).data.ownerUid
        );
      }

      // Activity-feed events ("X joined", "Y added a habit"). Reads are
      // gated on workspace membership. Creates require only that the
      // writer is the event's actor (so a member-left event can fire
      // even after the user removed themselves from memberUids; the
      // workspace membership check at create-time would deny that).
      // No updates — events are append-only. Owner can delete any
      // event (cascade-on-delete-workspace).
      match /events/{eventId} {
        allow read: if request.auth != null
          && request.auth.uid in get(
            /databases/$(database)/documents/workspaces/$(wsId)
          ).data.memberUids;
        allow create: if request.auth != null
          && request.auth.uid == request.resource.data.actorUid;
        allow delete: if request.auth != null
          && request.auth.uid == get(
            /databases/$(database)/documents/workspaces/$(wsId)
          ).data.ownerUid;
      }

      // Chat messages. Member-authored, unlike the events feed. Reads are
      // gated on workspace membership. A member can create a message only
      // as themselves (senderUid == auth.uid) AND only while a member, so
      // a non-member or a since-left user can't post. No updates —
      // messages are immutable. Delete is allowed for the sender (remove
      // your own message) or the workspace owner (moderation +
      // cascade-on-delete-workspace).
      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in get(
            /databases/$(database)/documents/workspaces/$(wsId)
          ).data.memberUids;
        allow create: if request.auth != null
          && request.auth.uid == request.resource.data.senderUid
          && request.auth.uid in get(
            /databases/$(database)/documents/workspaces/$(wsId)
          ).data.memberUids;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.senderUid
          || request.auth.uid == get(
            /databases/$(database)/documents/workspaces/$(wsId)
          ).data.ownerUid
        );
      }
    }

    // Public invite-code lookup. Any authenticated user can read (so a
    // join URL works on a fresh device) and create/delete (so owners
    // can rotate). The actual gate on joining lives in the workspace
    // doc's update rule above.
    match /workspaceInvites/{code} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null;
    }
  }
}
